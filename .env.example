# Supabase project URL — e.g. https://abcdefg.supabase.co
SUPABASE_URL=

# Service-role key (server-only, used by Next.js API routes).
# Get from: Supabase dashboard → Project Settings → API → "service_role" key.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string (used ONLY by the ingest script).
# Get from: Supabase dashboard → Project Settings → Database → Connection string → URI.
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_DB_URL=
